# ═══════════════════════════════════════════════════════════════
# Backport — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── App Settings ─────────────────────────────────────────────
ENVIRONMENT=development                    # "development" | "production" | "test"
PORT=8080                                  # Backend port

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./backport.db       # SQLite (dev) or postgresql://... (prod)

# ─── Security ─────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
ADMIN_SECRET=change-this-admin-secret

# ─── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@backport.in              # Your email — auto-promoted to admin on startup

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000         # Frontend URL (for CORS + email links)
CORS_ORIGINS=http://localhost:3000         # Comma-separated allowed origins

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx            # Get from https://resend.com
FROM_EMAIL=onboarding@yourdomain.com       # Must be verified in Resend

# ─── Payments (Razorpay) ─────────────────────────────────────
RAZORPAY_KEY_ID=rz_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OAuth Social Login (Optional) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
