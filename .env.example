# ── Backport Backend Environment Variables (Set on Render) ──────────────────

# ── Application ───────────────────────────────────────────────────────────
# Set to "production" in production, "development" or "test" locally
ENVIRONMENT=development

# Port the backend listens on (Render sets this automatically)
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────
# Full database connection URL. Defaults to local SQLite if not set.
# For production: postgresql://user:pass@host:5432/dbname
# For Render: set via Render dashboard (PostgreSQL addon recommended)
DATABASE_URL=sqlite:///./backport.db

# Legacy SQLite path (used as fallback when DATABASE_URL is not set)
DB_PATH=./backport.db

# ── Security ──────────────────────────────────────────────────────────────
# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# IMPORTANT: Use a strong key (min 32 chars) in production
SECRET_KEY=your-super-secret-key-change-this

# JWT algorithm for token encoding (default: HS256)
JWT_ALGORITHM=HS256

# ── Admin ─────────────────────────────────────────────────────────────────
# Admin email (auto-promoted to admin on first login)
ADMIN_EMAIL=your-email@example.com

# Admin secret (for admin panel access, bootstrap, and user deletion)
ADMIN_SECRET=your-admin-secret-change-this

# ── Frontend & CORS ───────────────────────────────────────────────────────
# Frontend URL (for CORS and email links)
FRONTEND_URL=https://backport.in

# CORS origins (comma-separated)
CORS_ORIGINS=https://backport.in

# ── OAuth — Google ────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-backend.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers
# Authorization callback URL: https://your-backend.onrender.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth State Secret ────────────────────────────────────────────────────
# Secret used to sign OAuth state parameter (anti-CSRF).
# Auto-generated if not set, but set explicitly for production to maintain
# session validity across restarts.
OAUTH_STATE_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=onboarding@yourdomain.com

# ── Payments (Razorpay) ──────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_SECRET_KEY

# ── Cache (Redis / Upstash) ──────────────────────────────────────────────
# Redis URL for caching and rate limiting. If not set, an in-memory
# fallback is used (not suitable for multi-instance deployments).
# For Upstash: redis://default:password@endpoint.upstash.io:port
REDIS_URL=

# ── Backport Frontend Environment Variables (Set on Vercel) ─────────────────

# Your Render backend URL (set this in Vercel dashboard → Settings → Env Vars)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
