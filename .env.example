# ── Backport Backend Environment Variables ─────────────────────────────────────

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-this

# SQLite DB path (use /app/data/backport.db on Render with persistent disk)
DB_PATH=./backport.db

# Razorpay (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_SECRET_KEY

# ── Backport Frontend Environment Variables ────────────────────────────────────

# Your Render backend URL (set this in Vercel dashboard)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
